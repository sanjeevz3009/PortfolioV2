# Copy this to .env and fill in values.
# .env is gitignored - never commit it.

# Your site's canonical URL - no trailing slash.
# Must match SITEURL in publishconf.py.
# Required for: make publish, local production builds.
# Set this in Vercel dashboard under Settings -> Environment Variables too.
SITEURL=https://sanj.ninja

# Sentry DSN - client-side error monitoring (optional).
# If using Sentry, add the Browser SDK snippet to base.html.
# Get your DSN from sentry.io after creating a project.
# SENTRY_DSN=
